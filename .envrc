unset DOCKER_HOST

use nix

# Short, per-project paths (avoid 104/108-byte unix socket limits)
proj="$(basename "$PWD" | tr -cd 'a-zA-Z0-9' | cut -c1-12)"
export DOCKER_BASE="/run/user/$UID/dk-$proj"
export DOCKER_HOST="unix://$DOCKER_BASE/d.sock"
export PATH="/run/wrappers/bin:$PATH"   # ensure setuid newuidmap/newgidmap

mkdir -p "$DOCKER_BASE"

# Separate RootlessKit state to avoid lock with your user daemon
export DOCKERD_ROOTLESS_ROOTLESSKIT_STATE_DIR="$DOCKER_BASE/rk"
export DOCKERD_ROOTLESS_ROOTLESSKIT_PORT_DRIVER=slirp4netns

daemon_ready_cli() {
    DOCKER_HOST="unix://$DOCKER_HOST" docker version --format '{{.Server.Version}}' >/dev/null 2>&1
}

# Start if not already running
if ! daemon_ready_cli; then
    echo "Starting rootless dockerd..."
    nohup dockerd-rootless \
        --data-root="$DOCKER_BASE/dr" \
        --exec-root="$DOCKER_BASE/ex" \
        --host="$DOCKER_HOST" \
        --pidfile=".direnv/docker.pid" \
        --storage-driver=fuse-overlayfs \
        --iptables=false \
        >".direnv/docker.log" 2>&1 &
fi

# Wait until it's ready, max 5 attempts
count=0
while ! daemon_ready_cli; do
    sleep 1
    count=$((count + 1))
    if [ $count -ge 5 ]; then
        echo "Failed to start Docker daemon after 5 attempts" >&2
        exit 1
    fi
done

echo "Docker daemon is ready"