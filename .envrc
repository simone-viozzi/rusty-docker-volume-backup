unset DOCKER_HOST
use nix

PATH_add docker-rootless  # if you vendor scripts here (chmod +x!)

set -euo pipefail

proj="$(basename "$PWD" | tr -cd 'a-zA-Z0-9' | cut -c1-12)"
# add a short hash so units don't clash across repos
hash="$(printf %s "$PWD" | sha256sum | cut -c1-6)"
export unit="docker-rootless-${proj}-${hash}"

: "${XDG_RUNTIME_DIR:?need /run/user/$(id -u)}"
SOCK="$XDG_RUNTIME_DIR/dk-${proj}-${hash}.sock"
export DOCKER_HOST="unix://$SOCK"

LAUNCHER="$PWD/docker-rootless/dockerd-rootless.sh"
DATA_BASE="$PWD/.direnv/docker-data"; mkdir -p "$DATA_BASE"
DATA_ROOT="$(readlink -fm "$DATA_BASE/dr")"; mkdir -p "$DATA_ROOT"

daemon_ready_cli(){ DOCKER_HOST="$DOCKER_HOST" docker version --format '{{.Server.Version}}' >/dev/null 2>&1; }

# If a unit with this name is already loaded, use it; else create a transient one.
if systemctl --user show -p LoadState --value "$unit" 2>/dev/null | grep -qx loaded; then
  # If it’s running, do nothing; else start it
  if ! systemctl --user is-active --quiet "$unit"; then
    systemctl --user start "$unit"
  fi
else
  # ensure no stale job remains
  systemctl --user reset-failed "$unit" >/dev/null 2>&1 || true

  sleep 1

  # create a fresh transient unit
  systemd-run --user \
    --unit="$unit" \
    --property=Type=simple \
    --property=Delegate=yes \
    --property=TasksMax=infinity \
    --property=LimitNOFILE=infinity \
    --property=LimitNPROC=infinity \
    --property=LimitCORE=infinity \
    --property=Restart=on-failure \
    --property=RestartSec=2s \
    --property=KillMode=mixed \
    --property=WorkingDirectory="$PWD" \
    --property=CollectMode=inactive-or-failed \
    --setenv=PATH="/run/wrappers/bin:$PATH" \
    --setenv=DOCKER_HOST="unix://$SOCK" \
    "$LAUNCHER" \
      --data-root "$DATA_ROOT" \
      --host "unix://$SOCK" \
      --storage-driver "fuse-overlayfs"
fi

# wait up to 15s
for _ in {1..15}; do daemon_ready_cli && break || sleep 1; done
if ! daemon_ready_cli; then
  echo "Docker failed to start. Logs:"
  echo "  journalctl --user -u $unit -n 200 --no-pager"
  exit 1
fi

# Wait up to ~15s for cold starts
for _ in {1..15}; do daemon_ready_cli && break || sleep 1; done
if ! daemon_ready_cli; then
  echo "Docker daemon failed to start. See logs:"
  echo "  journalctl --user -u $unit -n 200 --no-pager"
  exit 1
fi

echo "Docker ready at $DOCKER_HOST (unit: $unit)"

